{
  "name": "dialogue-translation-application",
  "version": "1.0.0",
  "description": "Desktop dialogue translation application with voice input and multi-language support",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:vite\" \"pnpm dev:electron\"",
    "dev:vite": "vite --config vite.config.ts",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build --config vite.config.ts",
    "build": "pnpm build:main && pnpm build:renderer",
    "build:python": "node scripts/build-python.mjs",
    "build:whisper": "node scripts/build-whisper.mjs",
    "electron:build": "pnpm build && pnpm build:python && pnpm build:whisper && electron-builder",
    "electron:build:voice": "bash scripts/check-macos-voice-signing.sh && pnpm electron:build",
    "postinstall": "electron-rebuild -m .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liwenkang/dialogue-translation-application.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/liwenkang/dialogue-translation-application/issues"
  },
  "homepage": "https://github.com/liwenkang/dialogue-translation-application#readme",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "opencc-js": "^1.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tinyld": "^1.3.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/opencc-js": "^1.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "postcss": "^8.5.9",
    "shx": "^0.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
